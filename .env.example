# Plex server base URL, for example http://10.10.1.202:32400
PLEX_URL=

# Plex token with access to the Movies library.
PLEX_TOKEN=

# Radarr base URL, for example http://10.10.1.202:7878
RADARR_URL=

# Radarr API key from Settings > General > Security.
RADARR_API_KEY=

SONARR_URL=

SONARR_API_KEY=

# Host-side movie root selected for this cleanup utility.
MOVIES_ROOT=/mnt/user/appdata/data/media/movies

TV_ROOT=/mnt/user/appdata/data/media/tv

# Container-to-host path mappings used when comparing Plex and Radarr paths.
# Format: container_prefix=host_prefix;container_prefix=host_prefix
PATH_MAPPINGS=/data/media/movies=/mnt/user/appdata/data/media/movies;/movies=/mnt/user/appdata/data/media/movies

# Container-to-host path mappings used when comparing Plex and Sonarr TV paths.
TV_PATH_MAPPINGS=/data/media/tv=/mnt/user/appdata/data/media/tv;/tv=/mnt/user/appdata/data/media/tv

# Where quarantine runs and manifests are written.
QUARANTINE_ROOT=/mnt/user/appdata/reclaimspace/quarantine

# Optional Plex movie section key. Leave blank to auto-detect the first movie library.
PLEX_MOVIE_SECTION=

# Plex TV Shows section key.
PLEX_TV_SECTION=
