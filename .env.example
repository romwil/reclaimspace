# Reclaimspace configuration — copy to .env and fill in values.
# See docs/CONFIGURATION.md for full reference.

# --- Plex ---
PLEX_URL=http://10.0.0.10:32400
PLEX_TOKEN=

# Plex library section keys (numeric), from /library/sections — not display titles.
PLEX_MOVIE_SECTION=
PLEX_TV_SECTION=

# --- Radarr (movies) ---
RADARR_URL=http://10.0.0.10:7878
RADARR_API_KEY=

# --- Sonarr (TV) ---
SONARR_URL=http://10.0.0.10:8989
SONARR_API_KEY=

# --- Host library roots (paths the tool must read on disk) ---
MOVIES_ROOT=/mnt/user/data/media/movies
TV_ROOT=/mnt/user/data/media/tv

# --- Path mappings: container_prefix=host_prefix;... ---
# Plex and *arr apps often use different prefixes for the same files.
PATH_MAPPINGS=/data/media/movies=/mnt/user/data/media/movies;/movies=/mnt/user/data/media/movies
TV_PATH_MAPPINGS=/data/media/tv=/mnt/user/data/media/tv;/tv=/mnt/user/data/media/tv

# --- Quarantine output (writable directory) ---
QUARANTINE_ROOT=/mnt/user/data/quarantine
